<section class="bg-white text-[#1a1a1a] py-16 lg:py-24 relative overflow-hidden">
  <div
    class="absolute top-[-5%] left-[-5%] w-[30%] h-[30%] bg-blue-50/40 rounded-full blur-[100px] pointer-events-none"
  ></div>
  <div
    class="absolute bottom-[10%] right-[-5%] w-[25%] h-[30%] bg-rose-50/30 rounded-full blur-[100px] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-6xl px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-7 animate-fadeUp">
        <span class="inline-block text-[10px] uppercase tracking-[0.3em] text-rose-600 font-bold mb-4">
          {{ section.settings.label | default: 'The Person Behind the Code' }}
        </span>

        <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif italic leading-[1.1] mb-6">
          {{ section.settings.heading }}
        </h2>

        <div class="text-base md:text-lg text-gray-500 font-light tracking-wide leading-relaxed mb-10 max-w-2xl">
          {{ section.settings.bio_text }}
        </div>

        <div class="flex flex-wrap gap-4">
          {% if section.settings.about_link != blank %}
            <a
              href="{{ section.settings.about_link }}"
              class="group relative inline-flex items-center justify-center px-8 py-4 font-semibold text-white bg-black rounded-full overflow-hidden transition-all duration-300 hover:scale-105 active:scale-95 shadow-xl"
            >
              <span class="relative z-10">More About Me</span>
              <div
                class="absolute inset-0 bg-gradient-to-r from-rose-400 to-rose-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              ></div>
            </a>
          {% endif %}

          {% if section.settings.linkedin_link != blank %}
            <a
              href="{{ section.settings.linkedin_link }}"
              target="_blank"
              class="inline-flex items-center justify-center px-8 py-4 font-semibold text-white bg-[#0077b5] rounded-full transition-all duration-300 hover:bg-[#005582] hover:scale-105 active:scale-95 shadow-lg gap-2"
            >
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
              LinkedIn Profile
            </a>
          {% endif %}
        </div>
      </div>

      <div class="lg:col-span-5 relative">
        <div class="grid grid-cols-2 gap-4 lg:gap-6 animate-float">
          {% for block in section.blocks %}
            {% if block.type == 'skill' %}
              <div class="bg-[#faf9f6] p-6 rounded-[2rem] border border-black/5 flex flex-col items-center justify-center text-center transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 group">
                <div class="w-16 h-16 mb-4 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all duration-500">
                  {% if block.settings.skill_icon != blank %}
                    <img
                      src="{{ block.settings.skill_icon | image_url: width: 100 }}"
                      alt="{{ block.settings.skill_name }}"
                      class="w-full h-full object-contain"
                    >
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'w-10 h-10 text-gray-200' }}
                  {% endif %}
                </div>
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold group-hover:text-black transition-colors">
                  {{ block.settings.skill_name }}
                </p>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="absolute -top-6 -right-6 bg-white/80 backdrop-blur-md p-6 rounded-3xl shadow-xl border border-white/20 hidden xl:block">
          <p class="text-3xl font-serif italic leading-none mb-1">99%</p>
          <p class="text-[9px] uppercase tracking-widest text-gray-400 font-bold">Client Satisfaction</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fadeUp {
    animation: fadeUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-15px);
    }
  }
</style>

{% schema %}
{
  "name": "Premium About & Skills",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Small Top Label",
      "default": "The Person Behind the Code"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Driven by design, fueled by coffee."
    },
    {
      "type": "textarea",
      "id": "bio_text",
      "label": "About Text",
      "default": "I specialize in creating pixel-perfect web experiences that combine technical performance with high-end aesthetic value."
    },
    {
      "type": "header",
      "content": "Links"
    },
    {
      "type": "url",
      "id": "about_link",
      "label": "Internal About Page Link"
    },
    {
      "type": "url",
      "id": "linkedin_link",
      "label": "LinkedIn Profile URL"
    }
  ],
  "blocks": [
    {
      "type": "skill",
      "name": "Skill",
      "settings": [
        {
          "type": "image_picker",
          "id": "skill_icon",
          "label": "Skill Icon (Logo)"
        },
        {
          "type": "text",
          "id": "skill_name",
          "label": "Skill Name",
          "default": "Tailwind CSS"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About & Skills",
      "blocks": [
        { "type": "skill", "settings": { "skill_name": "HTML5" } },
        { "type": "skill", "settings": { "skill_name": "CSS3" } },
        { "type": "skill", "settings": { "skill_name": "JavaScript" } },
        { "type": "skill", "settings": { "skill_name": "Tailwind" } }
      ]
    }
  ]
}
{% endschema %}
