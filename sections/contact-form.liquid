<div class="flex items-center justify-center py-12 bg-gray-50">
  {% form 'contact' %}
    <div class="w-full max-w-4xl bg-white shadow-lg rounded-2xl p-10">
      <h2 class="text-3xl font-semibold text-center text-gray-800 mb-8">{{ section.settings.form_name }}</h2>
      {% if form.errors %}
        <div class="border p-3 rounded-b-sm">
          <div class="flex flex-row items-center w-full my-3">
            <div class="text-red-500">
              {% render 'icon-failed' %}
            </div>
            <div class="text-sm font-medium ml-3">Oh! Something went wrong. Please try again..</div>
          </div>
          <ul class="px-4 mb-3 ml-7 list-decimal">
            {% for error in form.errors %}
              <li>
                <span>{{ form.errors.messages[error] }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% elsif form.posted_successfully? %}
        <div class="border p-3 rounded-b-sm">
          <div class="flex flex-row items-center w-full my-3">
            <div class="text-green-500">
              {% render 'icon-success' %}
            </div>
            <div class="text-sm font-medium ml-3">Comment posted successfully!</div>
          </div>
        </div>
      {% endif %}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Name -->
        <div class="flex flex-col space-y-2">
          <label for="contact_form" class="text-sm font-medium text-gray-600"> Name </label>
          <input
            type="text"
            name="contact[name]"
            id="contact_form"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black transition"
            placeholder="Enter your name"
          >
        </div>

        <!-- Email -->
        <div class="flex flex-col space-y-2">
          <label for="contact_email" class="text-sm font-medium text-gray-600"> Email Address </label>
          <input
            type="email"
            name="contact[email]"
            id="contact_email"
            class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black transition"
            placeholder="Enter your email"
          >
        </div>
      </div>

      <!-- Message (full width) -->
      <div class="flex flex-col space-y-2 mt-6">
        <label for="contact_message" class="text-sm font-medium text-gray-600"> Message </label>
        <textarea
          name="contact[body]"
          id="contact_message"
          rows="5"
          class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black transition resize-none"
          placeholder="Write your message..."
        ></textarea>
      </div>

      <!-- Button -->
      <button
        type="submit"
        class="w-full mt-6 bg-black text-white py-3 rounded-lg font-medium hover:bg-gray-800 transition duration-300"
      >
        Submit Message
      </button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "form_name",
      "label": "Form Title",
      "default": "Contact Form"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
