<section class="bg-white text-[#1a1a1a] py-16 lg:py-24 relative overflow-hidden">
  <div
    class="absolute bottom-[-5%] left-[-5%] w-[20%] h-[20%] bg-rose-50/50 rounded-full blur-[80px] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-6xl px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <div class="animate-fadeUp">
        <span class="inline-block text-[10px] uppercase tracking-[0.3em] text-rose-600 font-bold mb-4"
          >Get in Touch</span
        >
        <h2 class="text-4xl md:text-5xl font-serif italic leading-[1.1] mb-6">
          {{ section.settings.form_name }}
        </h2>
        <p class="text-[15px] text-gray-600 font-light tracking-wide leading-relaxed max-w-md">
          {{ section.settings.description }}
        </p>

        <div class="mt-10 pt-10 border-t border-black/5 hidden lg:block">
          <p class="text-[9px] uppercase tracking-[0.4em] text-gray-400 font-bold mb-2">Typically Responds Within</p>
          <p class="text-xl font-serif italic">24 Hours</p>
        </div>
      </div>

      <div class="animate-fadeUp" style="animation-delay: 0.2s;">
        {% form 'contact', class: 'w-full' %}
          {% if form.errors %}
            <div class="mb-6 p-4 bg-red-50 border border-red-100 rounded-2xl text-red-700 text-sm">
              <p class="font-bold mb-1 italic">Please correct the following:</p>
              {{ form.errors | default_errors }}
            </div>
          {% elsif form.posted_successfully? %}
            <div class="mb-6 p-4 bg-emerald-50 border border-emerald-100 rounded-2xl text-emerald-700 text-sm flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span>
              Message sent successfully. I'll be in touch soon!
            </div>
          {% endif %}

          <div class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="group">
                <label
                  for="contact_form"
                  class="text-[10px] uppercase tracking-widest text-gray-400 font-bold ml-1 mb-2 block transition-colors group-focus-within:text-black"
                >
                  Full Name
                </label>
                <input
                  type="text"
                  name="contact[name]"
                  id="contact_form"
                  class="w-full bg-[#faf9f6] border-none rounded-2xl px-5 py-4 focus:ring-2 focus:ring-black/5 transition-all outline-none placeholder:text-gray-300"
                  placeholder="Your Name"
                  required
                >
              </div>

              <div class="group">
                <label
                  for="contact_email"
                  class="text-[10px] uppercase tracking-widest text-gray-400 font-bold ml-1 mb-2 block transition-colors group-focus-within:text-black"
                >
                  Email Address
                </label>
                <input
                  type="email"
                  name="contact[email]"
                  id="contact_email"
                  class="w-full bg-[#faf9f6] border-none rounded-2xl px-5 py-4 focus:ring-2 focus:ring-black/5 transition-all outline-none placeholder:text-gray-300"
                  placeholder="hello@domain.com"
                  required
                >
              </div>
            </div>

            <div class="group">
              <label
                for="contact_message"
                class="text-[10px] uppercase tracking-widest text-gray-400 font-bold ml-1 mb-2 block transition-colors group-focus-within:text-black"
              >
                Project Details
              </label>
              <textarea
                name="contact[body]"
                id="contact_message"
                rows="4"
                class="w-full bg-[#faf9f6] border-none rounded-2xl px-5 py-4 focus:ring-2 focus:ring-black/5 transition-all outline-none placeholder:text-gray-300 resize-none"
                placeholder="Tell me about your goals..."
                required
              ></textarea>
            </div>

            <button
              type="submit"
              class="group relative w-full inline-flex items-center justify-center px-8 py-4 font-semibold text-white bg-black rounded-full overflow-hidden transition-all duration-300 hover:scale-[1.02] active:scale-95 shadow-xl"
            >
              <span class="relative z-10">Send Message</span>
              <div
                class="absolute inset-0 bg-gradient-to-r from-rose-400 to-rose-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              ></div>
            </button>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "form_name",
      "label": "Form Title",
      "default": "Let's start a conversation."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Form Description",
      "default": "I am currently exploring new job opportunities in web development and would love to connect with hiring teams. If you have an open role or are looking for someone to contribute to your projects, feel free to reach out. I am eager to bring value and grow within a strong, collaborative environment."
    }
  ],
  "presets": [
    {
      "name": "Premium Contact Form"
    }
  ]
}
{% endschema %}

<style>
  .animate-fadeUp {
    animation: fadeUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
