<section class="bg-[#faf9f6] text-[#1a1a1a] py-16 lg:py-24 relative overflow-hidden">
  <div
    class="absolute top-[10%] right-[-5%] w-[20%] h-[20%] bg-blue-50/40 rounded-full blur-[80px] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-6xl px-6 relative z-10">
    <div class="text-center mb-12 lg:mb-16 animate-fadeUp">
      <span class="inline-block text-[10px] uppercase tracking-[0.3em] text-rose-600 font-bold mb-3">
        {{ section.settings.label | default: 'Curated Selection' }}
      </span>

      <h2 class="text-4xl md:text-5xl font-serif italic mb-4">
        {{ section.settings.title }}
      </h2>

      {% if section.settings.description != blank %}
        <p class="text-gray-500 font-light tracking-wide max-w-2xl mx-auto leading-relaxed">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 lg:gap-8">
      {% for product in section.settings.featured_collection.products
        limit: section.settings.number_of_product_to_display
      %}
        <div class="group transition-all duration-500 hover:-translate-y-2">
          {% render 'product-cart', product_product: product %}
        </div>

      {% else %}
        {% for item in (1..section.settings.number_of_product_to_display) %}
          <div class="opacity-60">
            {% render 'product-card-placeholder' %}
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Small Top Label",
      "default": "Showcase"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured Projects"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A curated collection of my most recent works and digital products."
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "number_of_product_to_display",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Number Of Products"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}

<style>
  /* Ensuring consistent animations with the Hero section */
  .animate-fadeUp {
    animation: fadeUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Soft shadow for the product cards if they don't have one */
  .group:hover img {
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
  }
</style>
