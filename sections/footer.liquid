<footer class="relative overflow-hidden bg-black text-[#888888] mt-24">
  <div
    class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-rose-500/30 to-transparent"
  ></div>

  <div class="mx-auto max-w-[1400px] px-8 pt-20 pb-10 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 lg:gap-8 mb-20">
      <div class="md:col-span-5 flex flex-col items-center md:items-start">
        <a
          href="/"
          class="text-4xl font-serif italic text-white mb-8 tracking-tighter hover:text-rose-400 transition-all duration-500"
        >
          {{ shop.name }}
        </a>
        <p class="text-sm font-light leading-[1.8] max-w-sm text-gray-400">
          {{
            section.settings.footer_bio
            | default: 'Architecting high-performance digital solutions with a focus on minimalist aesthetics and technical excellence.'
          }}
        </p>
      </div>

      <div class="md:col-span-3 flex flex-col items-center md:items-start">
        <h3 class="text-[9px] uppercase tracking-[0.4em] text-rose-500 font-bold mb-10">The Navigation</h3>
        <ul class="space-y-5">
          {% for link in linklists[section.settings.footer_menu].links %}
            <li>
              <a
                href="{{ link.url }}"
                class="text-xs uppercase tracking-widest text-gray-300 hover:text-white transition-all duration-300 flex items-center gap-3 group"
              >
                <span class="h-[1px] w-0 bg-rose-500 transition-all duration-500 group-hover:w-5"></span>
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="md:col-span-4 flex flex-col items-center md:items-start">
        <h3 class="text-[9px] uppercase tracking-[0.4em] text-rose-500 font-bold mb-10">Get In Touch</h3>

        <div class="space-y-6 w-full">
          {% if section.settings.email != blank %}
            <a href="mailto:{{ section.settings.email }}" class="group block">
              <span class="text-[10px] text-gray-500 block mb-1 uppercase tracking-tighter">Direct Inquiry</span>
              <span class="text-white text-sm font-light group-hover:text-rose-400 transition-colors">
                {{- section.settings.email -}}
              </span>
            </a>
          {% endif %}

          <div class="flex items-center gap-5 pt-4">
            {% if section.settings.github != blank %}
              <a
                href="{{ section.settings.github }}"
                target="_blank"
                class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-white hover:text-black transition-all duration-500 transform hover:-translate-y-1"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.linkedin != blank %}
              <a
                href="{{ section.settings.linkedin }}"
                target="_blank"
                class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:bg-[#0077b5] hover:border-[#0077b5] hover:text-white transition-all duration-500 transform hover:-translate-y-1"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="relative pt-10 mt-10">
      <div class="absolute top-0 left-0 w-full h-[1px] bg-white/5"></div>
      <div
        class="absolute top-0 left-0 w-1/4 h-[1px] bg-gradient-to-r from-transparent via-rose-500/40 to-transparent"
      ></div>

      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-4">
          <p class="text-[9px] uppercase tracking-[0.3em] text-gray-600">
            &copy; {{ 'now' | date: '%Y' }}
            {{ shop.name }}
          </p>
          <span class="w-1 h-1 rounded-full bg-gray-800"></span>
          <p class="text-[9px] uppercase tracking-[0.3em] text-gray-600 italic">Fine Crafted Archive</p>
        </div>

        <div class="flex items-center gap-8">
          <p class="text-[9px] uppercase tracking-[0.3em] text-gray-500">Global Service</p>
          <p class="text-[9px] uppercase tracking-[0.3em] text-gray-500">Available for Hire</p>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Select Menu"
    },
    {
      "type": "textarea",
      "id": "footer_bio",
      "label": "Footer Bio"
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "github",
      "label": "GitHub URL"
    },
    {
      "type": "url",
      "id": "linkedin",
      "label": "LinkedIn URL"
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}
