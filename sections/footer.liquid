<footer class="bg-black text-gray-300 mt-16">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Store Info -->
      <div>
        <h2 class="text-xl font-semibold text-white mb-4">
          {{ shop.name }}
        </h2>
        <p class="text-sm text-gray-400">Thank you for visiting our store.</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-medium text-white mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {% for link in linklists[section.settings.footer_menu].links %}
            <li>
              <a href="{{ link.url }}" class="hover:text-white transition">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-medium text-white mb-4">Contact</h3>

        <div class="space-y-2 text-sm">
          {% if section.settings.phone != blank %}
            <p>
              📞
              <a href="tel:{{ section.settings.phone }}" class="hover:text-white">
                {{ section.settings.phone }}
              </a>
            </p>
          {% endif %}

          {% if section.settings.email != blank %}
            <p>
              ✉️
              <a href="mailto:{{ section.settings.email }}" class="hover:text-white">
                {{ section.settings.email }}
              </a>
            </p>
          {% endif %}
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-sm">
      <!-- Copyright -->
      <p class="text-gray-500">
        © {{ 'now' | date: '%Y' }}
        {{ shop.name }}. All rights reserved.
      </p>

      <!-- LinkedIn -->
      {% if section.settings.linkedin != blank %}
        <a href="{{ section.settings.linkedin }}" target="_blank" class="hover:text-white transition"> LinkedIn </a>
      {% endif %}
    </div>
  </div>

  {% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Select Menu"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Contact Number"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email"
    },
    {
      "type": "url",
      "id": "linkedin",
      "label": "LinkedIn URL"
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
  {% endschema %}
</footer>
