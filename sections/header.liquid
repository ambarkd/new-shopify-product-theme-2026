{% assign mobile_menu = section.settings.mobile_menu.links %}

<div
  class="fixed top-0 left-0 w-full z-50 bg-black border-b border-white/10 text-white"
  x-data="{ mobileMenuOpen: false, searchBarOpen: false }"
  x-cloak
>
  <div class="mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between py-5">
      <!-- LOGO -->
      <div class="flex-1">
        <a href="/" class="text-xl font-bold tracking-tight hover:opacity-80 transition">
          {{ shop.name }}
        </a>
      </div>

      <!-- DESKTOP NAV -->
      <div class="hidden md:flex flex-1 justify-center">
        <nav class="flex space-x-8 items-center">
          {% for link in section.settings.mobile_menu.links %}
            {% if link.links != blank %}
              <div
                class="relative"
                x-data="{ open: false }"
                @mouseenter="open = true"
                @mouseleave="open = false"
              >
                <a
                  href="{{ link.url }}"
                  class="flex items-center text-xs uppercase tracking-[0.2em] hover:text-gray-400 transition"
                >
                  {{ link.title }}
                  <span :class="{ 'rotate-180': open }" class="ml-1 transition-transform">
                    {% render 'icon-dropdown' %}
                  </span>
                </a>

                <div
                  x-show="open"
                  x-transition
                  class="absolute mt-4 w-52 bg-white text-black rounded-sm shadow-xl"
                  style="display:none;"
                >
                  <div class="p-4 space-y-3">
                    {% for childlink in link.links %}
                      <a href="{{ childlink.url }}" class="block text-sm hover:opacity-60 transition">
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>
              </div>
            {% else %}
              <a href="{{ link.url }}" class="text-xs uppercase tracking-[0.2em] hover:text-gray-400 transition">
                {{ link.title }}
              </a>
            {% endif %}
          {% endfor %}
        </nav>
      </div>

      <!-- RIGHT SIDE -->
      <div class="hidden md:flex flex-1 justify-end items-center space-x-6">
        <button @click="searchBarOpen = true" class="hover:text-gray-400 transition">
          {% render 'icon-search' %}
        </button>

        <a href="{{ routes.cart_url }}" class="relative hover:text-gray-400 transition">
          {% render 'icon-shopping-bag' %}
          {% if cart.item_count > 0 %}
            <span class="absolute -top-2 -right-2 bg-white text-black text-[10px] w-4 h-4 flex items-center justify-center rounded-full font-bold">
              {{ cart.item_count }}
            </span>
          {% endif %}
        </a>

        {% if shop.customer_accounts_enabled %}
          <a
            href="{{ routes.account_login_url }}"
            class="text-[10px] uppercase tracking-widest hover:text-gray-400 transition"
          >
            Login
          </a>
          <a
            href="{{ routes.account_register_url }}"
            class="text-[10px] uppercase tracking-widest border border-white px-3 py-1 hover:bg-white hover:text-black transition"
          >
            Register
          </a>
        {% endif %}
      </div>

      <!-- MOBILE -->
      <div class="md:hidden flex items-center space-x-2">
        <button @click="searchBarOpen = true" class="p-2">
          {% render 'icon-search' %}
        </button>

        <a href="{{ routes.cart_url }}" class="p-2 relative">
          {% render 'icon-shopping-bag' %}
          {% if cart.item_count > 0 %}
            <span class="absolute top-1 right-1 bg-white text-black text-[10px] w-4 h-4 flex items-center justify-center rounded-full">
              {{ cart.item_count }}
            </span>
          {% endif %}
        </a>

        <button @click="mobileMenuOpen = true" class="p-2">
          {% render 'icon-menu' %}
        </button>
      </div>
    </div>
  </div>

  <!-- MOBILE MENU -->
  <div
    x-show="mobileMenuOpen"
    x-transition
    class="fixed inset-0 bg-black z-50 md:hidden"
    style="display:none;"
  >
    <div class="p-6">
      <div class="flex justify-between items-center mb-10">
        <h2 class="text-xl font-bold uppercase">
          {{ section.settings.mobile_title }}
        </h2>
        <button @click="mobileMenuOpen = false" class="p-2 border border-white/10 rounded-full">
          {% render 'icon-close' %}
        </button>
      </div>

      <nav class="space-y-6">
        {% for link in mobile_menu %}
          {% if link.links != blank %}
            <div x-data="{ open: false }">
              <button
                @click="open = !open"
                class="flex justify-between w-full text-2xl font-light tracking-wide border-b border-white/5 pb-2"
              >
                {{ link.title }}
                <span :class="{ 'rotate-180': open }">
                  {% render 'icon-dropdown' %}
                </span>
              </button>

              <div x-show="open" class="pl-4 mt-4 space-y-3">
                {% for childlink in link.links %}
                  <a href="{{ childlink.url }}" class="block text-gray-400 text-lg">
                    {{ childlink.title }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% else %}
            <a href="{{ link.url }}" class="block text-2xl font-light tracking-wide border-b border-white/5 pb-2">
              {{ link.title }}
            </a>
          {% endif %}
        {% endfor %}
      </nav>

      {% if shop.customer_accounts_enabled %}
        <div class="mt-12 space-y-4">
          <a
            href="{{ routes.account_login_url }}"
            class="block w-full text-center py-4 border border-white/20 text-sm uppercase tracking-widest"
          >
            Login
          </a>
          <a
            href="{{ routes.account_register_url }}"
            class="block w-full text-center py-4 bg-white text-black font-bold text-sm uppercase tracking-widest"
          >
            Register
          </a>
        </div>
      {% endif %}
    </div>
  </div>

  <!-- SEARCH -->
  <div
    x-show="searchBarOpen"
    x-transition
    class="fixed top-0 left-0 w-full bg-black p-6 z-50 border-b border-white/10"
    style="display:none;"
  >
    <div class="max-w-2xl mx-auto flex items-center">
      <form action="{{ routes.search_url }}" method="get" class="flex-1">
        <div class="relative">
          <input
            type="search"
            name="q"
            placeholder="Search products..."
            class="w-full h-12 bg-transparent border-b border-white/20 text-white focus:outline-none focus:border-white"
          >
          <button type="submit" class="absolute right-0 top-1/2 -translate-y-1/2">
            {% render 'icon-search' %}
          </button>
        </div>
      </form>
      <button @click="searchBarOpen = false" class="ml-4 text-xs uppercase text-gray-400">Close</button>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "mobile_title",
      "label": "Mobile Menu Title",
      "default": "Menu"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
