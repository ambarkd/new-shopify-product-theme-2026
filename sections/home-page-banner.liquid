<section class="bg-black text-white pt-[75px]">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div class="text-center md:text-left">
        <h1 class="text-3xl md:text-5xl font-bold mb-6">
          {{ section.settings.heading }}
        </h1>

        <p class="text-gray-400 mb-8">
          {{ section.settings.subtext }}
        </p>

        {% if section.settings.button_text != blank %}
          <a
            href="{{ section.settings.button_link }}"
            class="inline-block bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-md transition shadow-lg shadow-green-500/20"
          >
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>

      <!-- Right Image -->
      <div class="flex justify-center">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 500 }}"
            alt="banner"
            class="w-64 h-64 md:w-80 md:h-80 object-cover rounded-full"
          >
        {% endif %}
      </div>
    </div>

    <!-- Tools Section -->
    {% if section.blocks.size > 0 %}
      <div class="mt-16 text-center md:text-left">
        <p class="text-gray-500 mb-6">Worked with</p>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6 items-center">
          {% for block in section.blocks %}
            <div class="flex justify-center md:justify-start opacity-70 hover:opacity-100 transition">
              {% if block.settings.logo != blank %}
                <img
                  src="{{ block.settings.logo | image_url: width: 120 }}"
                  alt="logo"
                  class="max-h-8 object-contain"
                >
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  {% schema %}
{
  "name": "Home Page Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Name Here"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Intro text goes here. Describe your work or brand."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Let's get started"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Image"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Tool Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Page Banner"
    }
  ]
}
  {% endschema %}
</section>
