<section class="bg-[#faf9f6] text-[#1a1a1a] pt-[100px] relative overflow-hidden">
  <div
    class="absolute top-[-10%] left-[-5%] w-[40%] h-[40%] bg-rose-100/40 rounded-full blur-[120px] pointer-events-none"
  ></div>
  <div
    class="absolute bottom-[-10%] right-[-5%] w-[30%] h-[40%] bg-blue-50/50 rounded-full blur-[100px] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-7xl px-6 py-20 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-7 text-center lg:text-left animate-fadeUp">
        <span class="inline-block text-xs uppercase tracking-[0.3em] text-rose-600 font-bold mb-4"
          >Available for Projects</span
        >

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif italic leading-[1.1] mb-8">
          {{ section.settings.heading }}
        </h1>

        <p class="text-lg text-gray-500 mb-10 max-w-xl mx-auto lg:mx-0 leading-relaxed font-light tracking-wide">
          {{ section.settings.subtext }}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          {% if section.settings.button_text != blank %}
            <a
              href="{{ section.settings.button_link }}"
              class="group relative inline-flex items-center justify-center px-8 py-4 font-semibold text-white bg-black rounded-full overflow-hidden transition-all duration-300 hover:scale-105 active:scale-95 shadow-2xl"
            >
              <span class="relative z-10">{{ section.settings.button_text }}</span>
              <div
                class="absolute inset-0 bg-gradient-to-r from-rose-400 to-rose-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              ></div>
            </a>
          {% endif %}

          <a
            href="#work"
            class="inline-flex items-center justify-center px-8 py-4 font-medium text-black border border-black/10 rounded-full hover:bg-black/5 transition-colors"
          >
            View Portfolio
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 flex justify-center lg:justify-end animate-float">
        {% if section.settings.image != blank %}
          <div class="relative group">
            <div
              class="absolute -inset-4 border border-black/5 rounded-[2rem] scale-95 group-hover:scale-100 transition-transform duration-700"
            ></div>

            <div class="relative w-72 h-80 md:w-96 md:h-[480px] overflow-hidden rounded-[2rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.2)]">
              <img
                src="{{ section.settings.image | image_url: width: 800 }}"
                alt="Profile"
                class="w-full h-full object-cover transform transition-transform duration-[2s] group-hover:scale-110"
              >
            </div>

            <div class="absolute -bottom-6 -left-6 bg-white/80 backdrop-blur-md p-4 rounded-2xl shadow-xl border border-white/20 hidden md:block">
              <p class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Experience</p>
              <p class="text-xl font-serif">5+ Years</p>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="mt-32 pt-12 border-t border-black/5">
        <p class="text-center text-[10px] uppercase tracking-[0.4em] text-gray-400 font-bold mb-10">Expertise In</p>

        <div class="flex flex-wrap gap-8 md:gap-16 items-center justify-center grayscale opacity-40">
          {% for block in section.blocks %}
            {% if block.settings.logo != blank %}
              <div class="flex-shrink-0 hover:grayscale-0 hover:opacity-100 transition-all duration-500 transform hover:-translate-y-1">
                <img
                  src="{{ block.settings.logo | image_url: width: 200 }}"
                  alt="logo"
                  class="h-8 md:h-10 w-auto object-contain"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  <style>
    /* Premium Animation Tweaks */
    .animate-fadeUp {
      animation: fadeUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-float {
      animation: float 6s ease-in-out infinite;
    }

    @keyframes float {
      0%,
      100% {
        transform: translateY(0px) rotate(0deg);
      }
      50% {
        transform: translateY(-20px) rotate(1deg);
      }
    }

    /* Remove scrollbar for tech stack if it overflows on mobile */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  {% schema %}
{
  "name": "Premium Home Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Crafting digital experiences." },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Focused on building high-end functional websites."
    },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Let's Talk" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "image_picker", "id": "image", "label": "Profile/Featured Image" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Tech Logo",
      "settings": [{ "type": "image_picker", "id": "logo", "label": "Logo Image" }]
    }
  ],
  "presets": [{ "name": "Premium Home Banner" }]
}
  {% endschema %}
</section>
