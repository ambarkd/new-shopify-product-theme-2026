<section class="bg-[#faf9f6] text-[#1a1a1a] pt-[80px] lg:pt-[100px] relative overflow-hidden">
  <div
    class="absolute top-[-5%] left-[-5%] w-[30%] h-[30%] bg-rose-100/30 rounded-full blur-[100px] pointer-events-none"
  ></div>
  <div
    class="absolute bottom-[10%] right-[-5%] w-[25%] h-[30%] bg-blue-50/40 rounded-full blur-[100px] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-6xl px-6 py-10 lg:py-14 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <div class="lg:col-span-7 text-center lg:text-left animate-fadeUp">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 mb-6">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span class="text-[10px] uppercase tracking-[0.2em] text-emerald-700 font-bold"
            >Open for New Opportunities</span
          >
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif italic leading-[1.1] mb-6">
          {{ section.settings.heading }}
        </h1>

        <p class="text-base md:text-lg text-gray-500 mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed font-light">
          {{ section.settings.subtext }}
        </p>

        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
          {% if section.settings.button_text != blank %}
            <a
              href="{{ section.settings.button_link }}"
              class="btn-premium bg-black text-white shadow-xl"
            >
              <span class="relative z-10">{{ section.settings.button_text }}</span>
              <div class="btn-overlay bg-gradient-to-r from-rose-400 to-rose-600"></div>
            </a>
          {% endif %}

          {% if section.settings.portfolio_link != blank %}
            <a
              href="{{ section.settings.portfolio_link }}"
              class="btn-premium text-black border border-black/10 shadow-sm"
            >
              <span class="relative z-10">{{ section.settings.portfolio_text | default: 'View Portfolio' }}</span>
              <div class="btn-overlay bg-black/5"></div>
            </a>
          {% endif %}
        </div>
      </div>

      <div class="lg:col-span-5 flex justify-center lg:justify-end animate-float">
        {% if section.settings.image != blank %}
          <div class="relative group">
            <div class="relative w-64 h-72 md:w-80 md:h-[400px] overflow-hidden rounded-[2.5rem] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.15)]">
              <img
                src="{{ section.settings.image | image_url: width: 800 }}"
                alt="Profile"
                class="w-full h-full object-cover transform transition-transform duration-[2s] group-hover:scale-105"
              >
            </div>
            <div class="absolute -bottom-4 -right-4 bg-white/95 backdrop-blur-md p-4 rounded-2xl shadow-lg border border-white/20 hidden sm:block">
              <p class="text-[9px] uppercase tracking-widest text-rose-600 font-bold mb-0.5">Experience</p>
              <p class="text-lg font-serif leading-none">3+ Years</p>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="mt-16 pt-8 border-t border-black/5">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <p class="text-[9px] uppercase tracking-[0.4em] text-gray-400 font-bold whitespace-nowrap">Expertise In</p>

          <div class="flex flex-wrap gap-6 md:gap-10 items-center justify-center">
            {% for block in section.blocks %}
              {% if block.settings.logo != blank %}
                <div class="logo-item flex-shrink-0 transition-all duration-500 transform hover:-translate-y-1">
                  <img
                    src="{{ block.settings.logo | image_url: width: 160 }}"
                    alt="logo"
                    class="h-6 md:h-7 w-auto object-contain filter-grayscale hover:filter-none opacity-50 hover:opacity-100 transition-all duration-500"
                  >
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}
  </div>

  <style>
    /* Premium Button Base */
    .btn-premium {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.875rem 1.75rem;
      font-weight: 600;
      border-radius: 9999px;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .btn-premium:hover {
      transform: scale(1.05);
    }

    .btn-premium:active {
      transform: scale(0.95);
    }

    .btn-overlay {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .btn-premium:hover .btn-overlay {
      opacity: 1;
    }

    /* Logo Hover Effects */
    .filter-grayscale {
      filter: grayscale(100%);
    }

    .animate-fadeUp {
      animation: fadeUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-float {
      animation: float 6s ease-in-out infinite;
    }

    @keyframes float {
      0%,
      100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-15px);
      }
    }
  </style>

  {% schema %}
{
  "name": "Premium Job Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Building Digital Excellence." },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Full-stack developer specializing in high-performance web applications."
    },
    { "type": "header", "content": "Primary Button (CTA)" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Hire Me" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Secondary Button (Portfolio)" },
    { "type": "text", "id": "portfolio_text", "label": "Portfolio Text", "default": "View Portfolio" },
    { "type": "url", "id": "portfolio_link", "label": "Portfolio Link" },
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Profile Image" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Tech Logo",
      "settings": [{ "type": "image_picker", "id": "logo", "label": "Logo Image" }]
    }
  ],
  "presets": [{ "name": "Premium Job Banner" }]
}
  {% endschema %}
</section>
