<section class="bg-gradient-to-b from-gray-950 via-gray-900 to-gray-800 text-white pt-[75px] relative overflow-hidden">
  <!-- Subtle Glow -->
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.06),transparent_40%)] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-6xl px-4 py-16 relative z-10">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div class="text-center md:text-left">
        <h1 class="text-3xl md:text-5xl font-semibold leading-tight mb-6">
          {{ section.settings.heading }}
        </h1>

        <p class="text-gray-400 mb-8 max-w-lg mx-auto md:mx-0">
          {{ section.settings.subtext }}
        </p>

        {% if section.settings.button_text != blank %}
          <a
            href="{{ section.settings.button_link }}"
            class="inline-block bg-white text-black px-6 py-3 rounded-md font-medium hover:bg-gray-200 transition shadow-lg"
          >
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>

      <!-- Right Image -->
      <div class="flex justify-center">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 500 }}"
            alt="banner"
            class="w-64 h-64 md:w-80 md:h-80 object-cover rounded-full border border-gray-700 shadow-xl"
          >
        {% endif %}
      </div>
    </div>

    <!-- Tools Section -->
    {% if section.blocks.size > 0 %}
      <div class="mt-16 text-center md:text-left">
        <p class="text-gray-500 mb-6 tracking-wide text-sm uppercase">Worked with</p>

        <!-- Logo Row -->
        <div class="flex gap-12 items-center justify-start md:justify-between overflow-x-auto no-scrollbar py-2">
          {% for block in section.blocks %}
            {% if block.settings.logo != blank %}
              <div class="flex-shrink-0 opacity-60 hover:opacity-100 hover:scale-105 transition duration-300">
                <img
                  src="{{ block.settings.logo | image_url: width: 180 }}"
                  alt="logo"
                  class="h-10 md:h-12 object-contain"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  <!-- Hide scrollbar -->
  <style>
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  {% schema %}
{
  "name": "Home Page Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Name Here"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Intro text goes here. Describe your work or brand."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Image"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Tool Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Page Banner"
    }
  ]
}
  {% endschema %}
</section>
