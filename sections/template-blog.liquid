<section class="bg-[#faf9f6] text-[#1a1a1a] py-16 lg:py-24 relative overflow-hidden">
  <div
    class="absolute top-[-5%] left-[-5%] w-[30%] h-[30%] bg-rose-100/20 rounded-full blur-[100px] pointer-events-none"
  ></div>

  {% paginate blog.articles by section.settings.number_of_blog_posts %}
    <div class="mx-auto max-w-6xl px-6 relative z-10">
      <div class="text-center mb-16 animate-fadeUp">
        <span class="inline-block text-[10px] uppercase tracking-[0.3em] text-rose-600 font-bold mb-4">
          {{ section.settings.blog_label | default: 'Insights & Thoughts' }}
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif italic leading-[1.1] mb-6">
          {{ blog.title }}
        </h1>
        {% if section.settings.blog_description != blank %}
          <p class="text-gray-500 font-light tracking-wide max-w-2xl mx-auto leading-relaxed">
            {{ section.settings.blog_description }}
          </p>
        {% endif %}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12">
        {% for article in blog.articles %}
          <article
            class="group flex flex-col animate-fadeUp"
            style="animation-delay: {{ forloop.index | times: 0.1 }}s;"
          >
            <a
              href="{{ article.url }}"
              class="block overflow-hidden rounded-[2rem] mb-6 shadow-sm group-hover:shadow-xl transition-all duration-500 transform group-hover:-translate-y-1"
            >
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.image.alt }}"
                  class="w-full h-64 object-cover transform transition-transform duration-[2s] group-hover:scale-110"
                  loading="lazy"
                >
              {% else %}
                <div class="w-full h-64 flex items-center justify-center bg-white">
                  {{ 'image' | placeholder_svg_tag: 'w-16 h-16 text-gray-200' }}
                </div>
              {% endif %}
            </a>

            <div class="flex items-center gap-3 mb-3">
              {% if section.settings.enable_author %}
                <span class="text-[9px] uppercase tracking-widest text-gray-400 font-bold"
                  >By {{ article.author -}}
                </span>
              {% endif %}
              <span class="w-1 h-1 rounded-full bg-rose-300"></span>
              <span class="text-[9px] uppercase tracking-widest text-gray-400 font-bold">
                {{- article.published_at | date: '%b %d, %Y' -}}
              </span>
            </div>

            <h2 class="text-2xl font-serif italic mb-4 transition-colors group-hover:text-rose-600">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h2>

            {% if section.settings.enable_excerpt %}
              <p class="text-gray-500 font-light leading-relaxed mb-6 line-clamp-3">
                {{ article.excerpt_or_content | strip_html | truncatewords: 20 }}
              </p>
            {% endif %}

            {% if section.settings.enable_view_more %}
              <div class="mt-auto">
                <a href="{{ article.url }}" class="btn-blog-premium">
                  <span class="relative z-10">Read Article</span>
                  <div class="btn-blog-overlay bg-black"></div>
                </a>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="mt-20 pt-10 border-t border-black/5 flex justify-center">
          {% render 'pagination', pagination: paginate %}
        </div>
      {% endif %}
    </div>
  {% endpaginate %}
</section>

<style>
  /* Blog Specific Premium Button */
  .btn-blog-premium {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 9999px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .btn-blog-premium:hover {
    color: white;
    border-color: black;
    transform: translateY(-2px);
  }

  .btn-blog-overlay {
    position: absolute;
    inset: 0;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .btn-blog-premium:hover .btn-blog-overlay {
    transform: translateY(0);
  }

  .animate-fadeUp {
    animation: fadeUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Image Aspect Ratio Control */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

{% schema %}
{
  "name": "Premium Blog Archive",
  "settings": [
    {
      "type": "text",
      "id": "blog_label",
      "label": "Small Top Label",
      "default": "The Archive"
    },
    {
      "type": "textarea",
      "id": "blog_description",
      "label": "Description",
      "default": "A collection of custom blog layouts and functionality created for this Shopify development store, along with insights from my development journey. Here I share practical learnings, challenges, and approaches used while building efficient and customizable solutions."
    },
    {
      "type": "range",
      "id": "number_of_blog_posts",
      "step": 1,
      "min": 3,
      "max": 12,
      "label": "Posts Per Page",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "enable_excerpt",
      "label": "Show Excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_view_more",
      "label": "Show 'Read Article' Button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_author",
      "label": "Show Author",
      "default": true
    }
  ]
}
{% endschema %}
