<div class="py-8">
  {% paginate blog.articles by section.settings.number_of_blog_posts %}
    <div class="py-10">
      <!-- Blog Title -->
      <h1 class="text-center text-3xl md:text-4xl font-bold mb-10 text-red-600">
        {{ blog.title }}
      </h1>

      <div class="mx-auto max-w-6xl px-4">
        <div class="grid grid-cols-1 sm:grid-cols-2  lg:grid-cols-3 gap-8">
          {% for article in blog.articles %}
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition duration-300 flex flex-col">
              <!-- Image -->
              {% if article.image %}
                <img
                  src="{{ article.image | image_url }}"
                  alt="{{ article.image.alt }}"
                  class="w-full h-56 object-cover"
                >
              {% else %}
                <div class="w-full h-56 flex items-center justify-center bg-gray-100">
                  {{ 'image' | placeholder_svg_tag: 'w-20 h-20 text-gray-400' }}
                </div>
              {% endif %}

              <!-- Content -->
              <div class="p-5 flex flex-col flex-grow">
                <!-- Top Content -->
                <div>
                  <!-- Title -->
                  <h2 class="text-lg font-semibold mb-2 hover:text-gray-700">
                    <a href="{{ article.url }}">
                      {{ article.title }}
                    </a>
                  </h2>

                  <!-- Excerpt -->
                  {% if section.settings.enable_excerpt %}
                    {% if article.excerpt.size > 0 %}
                      <p class="text-sm text-gray-600 mb-3">
                        {{ article.excerpt | strip_html | truncatewords: 25 }}
                      </p>
                    {% else %}
                      <p class="text-sm text-gray-600 mb-3">
                        {{ article.content | strip_html | truncatewords: 25 }}
                      </p>
                    {% endif %}
                  {% endif %}

                  <!-- Author -->
                  {% if section.settings.enable_author %}
                    <p class="mb-2">
                      <span class="text-xs text-gray-400 mb-4">By</span>
                      <span class="text-xs text-gray-700 mb-4"> {{ article.author }}</span>
                    </p>
                  {% endif %}
                </div>

                <!-- Button (always bottom) -->
                {% if section.settings.enable_view_more %}
                  <div class="mt-auto">
                    <a
                      href="{{ article.url }}"
                      class="inline-block bg-black text-white px-6 py-2 rounded-md text-sm font-medium hover:bg-gray-800 transition duration-200"
                    >
                      View more
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="max-w-6xl mx-auto">
      {% render 'pagination', pagination: paginate %}
    </div>
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Blog",
  "settings": [
    {
      "type": "range",
      "id": "number_of_blog_posts",
      "step": 1,
      "min": 1,
      "max": 10,
      "label": "Blog Post Per Page",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "enable_excerpt",
      "label": "Show Excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_view_more",
      "label": "Show View More Button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_author",
      "label": "Show Author",
      "default": true
    }
  ]
}
{% endschema %}
