<section class="bg-[#faf9f6] text-[#1a1a1a] pt-[130px] pb-12 lg:pb-20 relative overflow-hidden min-h-screen">
  <div
    class="absolute top-[-5%] right-[-5%] w-[25%] h-[25%] bg-blue-50/40 rounded-full blur-[100px] pointer-events-none"
  ></div>
  <div
    class="absolute bottom-[20%] left-[-5%] w-[20%] h-[30%] bg-rose-50/30 rounded-full blur-[100px] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-[1400px] px-6 relative z-10">
    <div class="mb-16 animate-fadeUp">
      <nav class="flex justify-center mb-8">
        <a
          href="{{ routes.collections_url }}"
          class="group flex items-center gap-2 text-[10px] uppercase tracking-[0.3em] text-gray-400 hover:text-rose-600 transition-colors"
        >
          <span class="transform group-hover:-translate-x-1 transition-transform">←</span>
          Back to Collections
        </a>
      </nav>

      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-serif italic leading-tight mb-6">
          {{ collection.title }}
        </h1>

        {% if collection.description != blank or section.settings.fallback_description != blank %}
          <p class="text-gray-500 font-light tracking-wide max-w-2xl mx-auto leading-relaxed text-lg">
            {{ collection.description | default: section.settings.fallback_description }}
          </p>
        {% endif %}
      </div>
    </div>

    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[35px]">
      {% for product in collection.products %}
        <div
          class="product-item {% if forloop.index > 4 %}hidden-product{% endif %} group animate-fadeUp"
          style="animation-delay: {{ forloop.index0 | modulo: 4 | times: 0.1 }}s;"
        >
          {% render 'product-cart', product_product: product, show_vendor: section.settings.show_vendor %}
        </div>
      {% else %}
        <div class="col-span-full py-20 text-center">
          <p class="text-gray-400 font-serif italic text-xl">No treasures found in this collection.</p>
        </div>
      {% endfor %}
    </div>

    {% if collection.products.size > 4 %}
      <div class="mt-20 flex flex-col items-center gap-4">
        <button id="see-more-btn" class="btn-premium bg-black text-white shadow-xl">
          <span class="relative z-10">See More</span>
          <div class="btn-overlay bg-gradient-to-r from-rose-400 to-rose-600"></div>
        </button>
        <p id="product-count" class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold">
          Showing 4 of {{ collection.products.size }} items
        </p>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('see-more-btn');
    const countText = document.getElementById('product-count');
    const totalItems = {{ collection.products.size }};
    let currentlyShown = 4;

    if (btn) {
      btn.addEventListener('click', function() {
        const hiddenItems = document.querySelectorAll('.hidden-product');
        
        // Show next 4 items
        for (let i = 0; i < 4; i++) {
          if (hiddenItems[i]) {
            hiddenItems[i].classList.remove('hidden-product');
            hiddenItems[i].classList.add('animate-fadeUp');
            currentlyShown++;
          }
        }

        // Update count text
        countText.innerText = `Showing ${currentlyShown} of ${totalItems} items`;

        // Hide button if no more items
        if (currentlyShown >= totalItems) {
          btn.parentElement.style.display = 'none';
        }
      });
    }
  });
</script>

<style>
  /* Premium Interaction Styles */
  .hidden-product {
    display: none;
  }

  .btn-premium {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2.5rem;
    font-weight: 600;
    border-radius: 9999px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .btn-premium:hover {
    transform: scale(1.05);
  }

  .btn-overlay {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .btn-premium:hover .btn-overlay {
    opacity: 1;
  }

  .animate-fadeUp {
    animation: fadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

{% schema %}
{
  "name": "Template Collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show Vendor Name"
    },
    {
      "type": "textarea",
      "id": "fallback_description",
      "label": "Fallback Description",
      "default": "Explore our curated selection of high-quality digital assets and products."
    }
  ]
}
{% endschema %}
