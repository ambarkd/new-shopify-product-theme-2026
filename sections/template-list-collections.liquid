<section class="bg-[#faf9f6] text-[#1a1a1a] pt-[130px] pb-12 lg:pb-20 relative overflow-hidden min-h-screen">
  <div
    class="absolute top-[-5%] left-[-5%] w-[30%] h-[30%] bg-rose-100/20 rounded-full blur-[100px] pointer-events-none"
  ></div>
  <div
    class="absolute bottom-[10%] right-[-5%] w-[25%] h-[30%] bg-blue-50/40 rounded-full blur-[100px] pointer-events-none"
  ></div>

  <div class="mx-auto max-w-[1400px] px-6 relative z-10">
    <div class="text-center mb-12 animate-fadeUp">
      <span class="inline-block text-[10px] uppercase tracking-[0.3em] text-rose-600 font-bold mb-4">
        {{ section.settings.label | default: 'The Collection Archive' }}
      </span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif italic leading-[1.1] mb-4">
        {{ section.settings.page_title }}
      </h1>
      {% if section.settings.description != blank %}
        <p class="text-gray-400 font-light tracking-wide max-w-xl mx-auto leading-relaxed text-sm">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </div>

    {% paginate collections by 50 %}
      <div id="collection-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 lg:gap-8">
        {% for collection in collections %}
          <div
            class="collection-item group animate-fadeUp"
            style="animation-delay: {{ forloop.index0 | modulo: 5 | times: 0.1 }}s;"
          >
            <a href="{{ collection.url }}" class="block">
              <div class="relative overflow-hidden rounded-[1.5rem] shadow-sm transition-all duration-500 mb-4 aspect-[4/5]">
                {% assign collection_image = collection.featured_image
                  | default: collection.products.first.featured_image
                %}

                {% if collection_image != blank %}
                  <img
                    src="{{ collection_image | image_url: width: 600 }}"
                    alt="{{ collection.title | escape }}"
                    class="w-full h-full object-cover transform transition-transform duration-[1.5s] group-hover:scale-105"
                  >
                {% else %}
                  <div class="w-full h-full flex items-center justify-center bg-white border border-black/5 rounded-[1.5rem]">
                    {{ 'collection-1' | placeholder_svg_tag: 'w-12 h-12 text-gray-200' }}
                  </div>
                {% endif %}

                <div
                  class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                ></div>
              </div>

              <div class="text-center lg:text-left px-1">
                <h2 class="text-lg font-serif italic mb-1 transition-colors group-hover:text-rose-600">
                  {{ collection.title }}
                </h2>
                <p class="text-[8px] uppercase tracking-[0.2em] text-gray-400 font-bold">
                  {{ collection.all_products_count }} Items
                </p>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="mt-12 flex justify-center border-t border-black/5 pt-8">
          {% render 'pagination', pagination: paginate %}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

<style>
  .animate-fadeUp {
    animation: fadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Refined hover state for the whole card */
  .collection-item:hover {
    transform: translateY(-3px);
    transition: transform 0.4s ease;
  }
</style>

{% schema %}
{
  "name": "Template List Collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Small Top Label",
      "default": "The Collection Archive"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "All Collections"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A curated archive of digital resources."
    }
  ]
}
{% endschema %}
